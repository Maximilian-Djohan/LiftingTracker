# URL of the RAG coach backend (the Cloudflare Worker that runs search + Claude).
# Dev:  leave unset — the app defaults to the local rag-bot server at http://localhost:8787
# Prod: set to your deployed Worker URL, e.g. https://fitness-coach.<your-subdomain>.workers.dev
#       Vite bakes this in at build time, so set it before `npm run build`.
VITE_RAG_API_URL=
